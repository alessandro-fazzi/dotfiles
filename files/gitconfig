[user]
	name = Alessandro Fazzi
	email = alessandro.fazzi@welaika.com
	signingkey = /Users/fuzzy/.ssh/id_ed25519.pub

[core]
	autocrlf = input
	safecrlf = true
	filemode = true
	excludesfile = ~/.gitignore
	pager = delta

[diff]
	submodule = log
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[pull]
	rebase = true

[push]
	default = current
	default = simple
	autoSetupRemote = true
	followTags = true

[fetch]
	prune = true
	pruneTags = true
	all = true

[status]
	submodulesummary = 1

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[init]
	defaultBranch = main

[gpg]
	format = ssh

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[help]
	autocorrect = prompt

[commit]
	verbose = true
	gpgsign = true

[rerere]
	enabled = true
	autoupdate = true

[alias]
	# assume-unchanged
	assume = update-index --assume-unchanged
	unassume = update-index --no-assume-unchanged
	assumed = "!git ls-files -v | grep ^h | cut -c 3-"
	unassumeall = "!git assumed | xargs git update-index --no-assume-unchanged"
	assumeall = "!git st -s | awk {'print $2'} | xargs git assume"
	c = commit -S
	cm = commit -S -m
	ap = add -p
	all = add .
	st = status
	pf = push --force-with-lease
	rmignored = "!git ls-files -o -i --exclude-standard | xargs git rm --cached"
	l = log --graph -10 HEAD --pretty=one-line-with-date
	ls = log --graph --branches --remotes -20 --pretty=one-line-with-date
	reco = commit --amend --no-edit
	recore = commit --amend
	gone = !git branch -vv | grep ': gone]' | awk '{print $1}'
	# `fish -c` is needed because git runs "!"-aliases through the system shell,
	# not fish, so autoloaded fish functions aren't otherwise visible here.
	ontop = "!fish -c git-ontop"
	ifix = "!fish -c git-ifix"
	ireword = "!fish -c git-ireword"
	isplit = "!fish -c git-isplit"

[color "status"]
	changed = yellow

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	hyperlinks = true
	hyperlinks-file-link-format = "zed://file/{path}:{line}"
	side-by-side = true
	theme = Monokai Extended
	dark = true

[pretty]
	one-line-with-date = tformat:%C(auto)%h%d %s %C(dim)%ad%C(reset)

[log]
	date = short

[merge]
	# conflictstyle = zdiff3

[http]
	sslVerify = true
